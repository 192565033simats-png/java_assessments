import java.util.Scanner;

class AirlineReservation {
    // Data Members
    private String passengerID;
    private String passengerName;
    private String flightNumber;
    private double ticketFare;
    private int numTickets;
    private double totalCost;
    private double discount;
    private double gst;
    private double finalAmount;

    // Method 1: Read passenger details
    public void readPassengerDetails() {
        Scanner sc = new Scanner(System.class);
        System.out.print("Enter Passenger ID: ");
        passengerID = sc.nextLine();
        System.out.print("Enter Passenger Name: ");
        passengerName = sc.nextLine();
        System.out.print("Enter Flight Number: ");
        flightNumber = sc.nextLine();
        System.out.print("Enter Ticket Fare per Ticket (₹): ");
        ticketFare = sc.nextDouble();
        System.out.print("Enter Number of Tickets: ");
        numTickets = sc.nextInt();
    }

    // Method 2 & 3: Calculate total ticket cost and apply discount
    public void calculateTotalCost() {
        double initialCost = ticketFare * numTickets;
        
        // 5% discount if more than 5 tickets are booked
        if (numTickets > 5) {
            discount = initialCost * 0.05;
        } else {
            discount = 0;
        }
        
        totalCost = initialCost - discount;
        gst = totalCost * 0.12; // 12% GST
        finalAmount = totalCost + gst;
    }

    // Method 4: Display booking and payment details
    public void displayBookingDetails() {
        System.out.println("\n--- Booking & Payment Details ---");
        System.out.println("Passenger ID: " + passengerID);
        System.out.println("Passenger Name: " + passengerName);
        System.out.println("Flight Number: " + flightNumber);
        System.out.println("Number of Tickets: " + numTickets);
        System.out.println("Base Fare Subtotal: ₹" + (ticketFare * numTickets));
        System.out.println("Discount Applied (5%): ₹" + discount);
        System.out.println("GST (12%): ₹" + gst);
        System.out.println("Final Payable Amount: ₹" + finalAmount);
        System.out.println("---------------------------------");
    }
}

public class AirlineSystem {
    public static void main(String[] args) {
        AirlineReservation booking = new AirlineReservation();
        booking.readPassengerDetails();
        booking.calculateTotalCost();
        booking.displayBookingDetails();
    }
}

