import java.util.Scanner;

class ProductionMonitor {
    // Data Members
    private String productID;
    private String productName;
    private double targetQuantity;
    private double producedQuantity;
    private double efficiency;

    // Method 1: Read product details
    public void readProductDetails() {
        Scanner sc = new Scanner(System.class);
        System.out.print("Enter Product ID: ");
        productID = sc.nextLine();
        System.out.print("Enter Product Name: ");
        productName = sc.nextLine();
        System.out.print("Enter Target Quantity: ");
        targetQuantity = sc.nextDouble();
        System.out.print("Enter Produced Quantity: ");
        producedQuantity = sc.nextDouble();
    }

    // Method 2 & 3: Compare actual production and calculate efficiency
    public void calculateEfficiency() {
        if (targetQuantity > 0) {
            efficiency = (producedQuantity / targetQuantity) * 100;
        } else {
            efficiency = 0;
        }
    }

    // Method 4: Display production status
    public void displayProductionStatus() {
        String status = (producedQuantity >= targetQuantity) ? "Achieved" : "Not Achieved";
        
        System.out.println("\n--- Production Monitoring Status ---");
        System.out.println("Product ID: " + productID);
        System.out.println("Product Name: " + productName);
        System.out.println("Target Quantity: " + targetQuantity);
        System.out.println("Produced Quantity: " + producedQuantity);
        System.out.printf("Production Efficiency: %.2f%%\n", efficiency);
        System.out.println("Production Status: " + status);
        System.out.println("------------------------------------");
    }
}

public class ManufacturingSystem {
    public static void main(String[] args) {
        ProductionMonitor pm = new ProductionMonitor();
        pm.readProductDetails();
        pm.calculateEfficiency();
        pm.displayProductionStatus();
    }
}

