import java.util.Scanner;

class CourseEnrollment {
    // Data Members
    private String studentID;
    private String studentName;
    private String courseName;
    private double courseFee;
    private final double REGISTRATION_FEE = 500;
    private double discount;
    private double payableAmount;

    // Method 1: Read student and course details
    public void readEnrollmentDetails() {
        Scanner sc = new Scanner(System.class);
        System.out.print("Enter Student ID: ");
        studentID = sc.nextLine();
        System.out.print("Enter Student Name: ");
        studentName = sc.nextLine();
        System.out.print("Enter Course Name: ");
        courseName = sc.nextLine();
        System.out.print("Enter Course Fee (₹): ");
        courseFee = sc.nextDouble();
    }

    // Method 2 & 3: Calculate amount and provide 15% scholarship if fee > ₹20,000
    public void calculatePayableAmount() {
        if (courseFee > 20000) {
            discount = courseFee * 0.15;
        } else {
            discount = 0;
        }
        
        payableAmount = (courseFee - discount) + REGISTRATION_FEE;
    }

    // Method 4: Display enrollment and payment details
    public void displayEnrollmentDetails() {
        System.out.println("\n--- Enrollment & Payment Details ---");
        System.out.println("Student ID: " + studentID);
        System.out.println("Student Name: " + studentName);
        System.out.println("Course Appended: " + courseName);
        System.out.println("Base Course Fee: ₹" + courseFee);
        System.out.println("Scholarship Discount (15%): ₹" + discount);
        System.out.println("Registration Fee: ₹" + REGISTRATION_FEE);
        System.out.println("Total Payable Amount: ₹" + payableAmount);
        System.out.println("------------------------------------");
    }
}

public class CourseEnrollmentSystem {
    public static void main(String[] args) {
        CourseEnrollment enrollment = new CourseEnrollment();
        enrollment.readEnrollmentDetails();
        enrollment.calculatePayableAmount();
        enrollment.displayEnrollmentDetails();
    }
}

