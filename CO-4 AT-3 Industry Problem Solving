import java.util.Scanner;
class Patient {
    // Data Members
    private String patientID;
    private String patientName;
    private String roomType;
    private int daysAdmitted;
    private double treatmentCharges;
    private double roomCharges;
    private double totalBill;

    // Method 1: Read patient details
    public void readPatientDetails() {
        Scanner sc = new Scanner(System.class);
        System.out.print("Enter Patient ID: ");
        patientID = sc.nextLine();
        System.out.print("Enter Patient Name: ");
        patientName = sc.nextLine();
        System.out.print("Enter Room Type (General/Special): ");
        roomType = sc.nextLine();
        System.out.print("Enter Number of Days Admitted: ");
        daysAdmitted = sc.nextInt();
        System.out.print("Enter Treatment Charges (₹): ");
        treatmentCharges = sc.nextDouble();
    }

    // Method 2: Calculate room charges based on room type
    public void calculateRoomCharges() {
        if (roomType.equalsIgnoreCase("Special")) {
            roomCharges = daysAdmitted * 3000;
        } else {
            roomCharges = daysAdmitted * 1500; // Defaulting to General if not special
        }
    }

    // Method 3: Calculate the total hospital bill
    public void calculateTotalBill() {
        totalBill = roomCharges + treatmentCharges;
    }

    // Method 4: Display patient billing details
    public void displayBillingDetails() {
        System.out.println("\n--- Patient Billing Details ---");
        System.out.println("Patient ID: " + patientID);
        System.out.println("Patient Name: " + patientName);
        System.out.println("Room Type: " + roomType);
        System.out.println("Days Admitted: " + daysAdmitted);
        System.out.println("Room Charges: ₹" + roomCharges);
        System.out.println("Treatment Charges: ₹" + treatmentCharges);
        System.out.println("Total Bill Amount: ₹" + totalBill);
        System.out.println("--------------------------------");
    }
}

public class HospitalBillingSystem {
    public static void main(String[] args) {
        Patient patient = new Patient();
        patient.readPatientDetails();
        patient.calculateRoomCharges();
        patient.calculateTotalBill();
        patient.displayBillingDetails();
    }
}

