import java.util.Scanner;

class Student {
    private String studentID;
    private String studentName;
    private String course;
    private double feeBalance;

    // Constructor with initial Total Course Fee assumed to be 50,000
    public Student() {
        this.feeBalance = 50000.0;
    }

    // 1. Read student details
    public void readStudentDetails() {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter Student ID: ");
        studentID = sc.nextLine();
        System.out.print("Enter Student Name: ");
        studentName = sc.nextLine();
        System.out.print("Enter Course: ");
        course = sc.nextLine();
    }

    // 2. Pay fee amount
    public void payFee(double amount) {
        if (amount <= 0) {
            System.out.println("Invalid payment amount.");
        } else if (amount > feeBalance) {
            System.out.println("Paying excess amount. Remaining balance is only: INR " + feeBalance);
        } else {
            feeBalance -= amount;
            System.out.println("\n--- Payment of INR " + amount + " Successful! ---");
        }
    }

    // 3. Check remaining fee balance
    public void checkFeeBalance() {
        System.out.println("Current Fee Balance: INR " + feeBalance);
    }

    // 4. Display student details
    public void displayStudentDetails() {
        System.out.println("\n====== Student Details ======");
        System.out.println("Student ID   : " + studentID);
        System.out.println("Student Name : " + studentName);
        System.out.println("Course       : " + course);
        System.out.println("Fee Balance  : INR " + feeBalance);
        System.out.println("=============================");
    }
}

public class StudentFeeManagement {
    public static void main(String[] args) {
        Student student = new Student();
        
        System.out.println("--- Reading Student Details ---");
        student.readStudentDetails();
        student.displayStudentDetails();
        
        System.out.println("\nMaking a payment of INR 15,000...");
        student.payFee(15000);
        
        System.out.println("\nChecking remaining balance directly:");
        student.checkFeeBalance();
        
        student.displayStudentDetails();
    }
}

