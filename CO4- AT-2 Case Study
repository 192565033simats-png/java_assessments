import java.util.Scanner;

class Consumer {
    private String consumerNumber;
    private String consumerName;
    private String typeOfConnection;
    private double unitsConsumed;

    // 1. Read consumer details
    public void readConsumerDetails() {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter Consumer Number: ");
        consumerNumber = sc.nextLine();
        System.out.print("Enter Consumer Name: ");
        consumerName = sc.nextLine();
        
        // Loop until valid input is received
        while (true) {
            System.out.print("Enter Type of Connection (Domestic/Commercial): ");
            typeOfConnection = sc.nextLine();
            if (validateConnectionType()) {
                break;
            } else {
                System.out.println("Invalid Connection Type! Please try again.");
            }
        }
        
        System.out.print("Enter Units Consumed: ");
        unitsConsumed = sc.nextDouble();
    }

    // 4. Validate connection type
    public boolean validateConnectionType() {
        return typeOfConnection.equalsIgnoreCase("Domestic") || typeOfConnection.equalsIgnoreCase("Commercial");
    }

    // 2. Calculate electricity bill
    public double calculateBill() {
        if (typeOfConnection.equalsIgnoreCase("Domestic")) {
            return unitsConsumed * 5;
        } else if (typeOfConnection.equalsIgnoreCase("Commercial")) {
            return unitsConsumed * 8;
        }
        return 0;
    }

    // 3. Display bill amount
    public void displayBill() {
        double billAmount = calculateBill();
        System.out.println("\n====== Electricity Bill ======");
        System.out.println("Consumer No   : " + consumerNumber);
        System.out.println("Consumer Name : " + consumerName);
        System.out.println("Connection    : " + typeOfConnection);
        System.out.println("Units Consumed: " + unitsConsumed);
        System.out.println("------------------------------");
        System.out.println("Total Bill    : INR " + billAmount);
        System.out.println("==============================");
    }
}

public class ElectricityBillManagement {
    public static void main(String[] args) {
        Consumer consumer = new Consumer();
        System.out.println("--- Reading Consumer Details ---");
        consumer.readConsumerDetails();
        consumer.displayBill();
    }
}

