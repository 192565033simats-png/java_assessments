import java.util.Scanner;

class MobileSubscriber {
    private String mobileNumber;
    private String subscriberName;
    private String serviceProvider;
    private double accountBalance;

    // Constructor with initial balance assumed to be 500
    public MobileSubscriber() {
        this.accountBalance = 500.0;
    }

    // 1. Read subscriber details
    public void readSubscriberDetails() {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter Mobile Number: ");
        mobileNumber = sc.nextLine();
        System.out.print("Enter Subscriber Name: ");
        subscriberName = sc.nextLine();
        System.out.print("Enter Service Provider: ");
        serviceProvider = sc.nextLine();
    }

    // 2. Recharge account balance
    public void recharge(double amount) {
        if (amount > 0) {
            accountBalance += amount;
            System.out.println("\n--- Recharge of INR " + amount + " Successful! ---");
        } else {
            System.out.println("Invalid recharge amount.");
        }
    }

    // 3. Deduct balance for a call/data usage
    public void deductBalance(double usageCost) {
        if (usageCost <= accountBalance) {
            accountBalance -= usageCost;
            System.out.println("\n--- Cost of INR " + usageCost + " deducted for usage. ---");
        } else {
            System.out.println("\n--- Insufficient balance for this action! Please recharge. ---");
        }
    }

    // 4. Display updated balance
    public void displayBalance() {
        System.out.println("\n====== Subscriber Balance Info ======");
        System.out.println("Subscriber Name : " + subscriberName);
        System.out.println("Mobile Number   : " + mobileNumber);
        System.out.println("Provider        : " + serviceProvider);
        System.out.println("Current Balance : INR " + accountBalance);
        System.out.println("=====================================");
    }
}

public class MobileRechargeSystem {
    public static void main(String[] args) {
        MobileSubscriber subscriber = new MobileSubscriber();
        
        System.out.println("--- Reading Subscriber Details ---");
        subscriber.readSubscriberDetails();
        subscriber.displayBalance();
        
        System.out.println("\nSimulating usage cost of INR 45...");
        subscriber.deductBalance(45);
        subscriber.displayBalance();
        
        System.out.println("\nRecharging with INR 200...");
        subscriber.recharge(200);
        subscriber.displayBalance();
    }
}

